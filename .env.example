# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.

# ── Required for running the app (report scoring + dataset generation) ──
OPENAI_API_KEY=sk-...

# ── Required for generate_report_dataset.py ──
# Path to your local ReXGradient-160K dataset directory
REXGRADIENT=/path/to/rexgradient

# ── Report scorer (default: gpt) ──
# "gpt" uses OpenAI o3 — no extra setup needed.
# "medgemma" requires a local MedGemma + LoRA checkpoint (HPC/research use).
REPORT_SCORER=gpt
