# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.

# ── Required for running the app (report scoring + dataset generation) ──
OPENAI_API_KEY=sk-...

# ── Required for generate_report_dataset.py, but not for running the app on the premade dataset ──
REXGRADIENT=/path/to/rexgradient

# ── Required for generate_localize_dataset.py, but not for running the app on the premade dataset ──
PADCHEST_GR=/path/to/Padchest_GR_files/PadChest_GR

# ── Report scorer (default: gpt) ──
# default: "gpt" uses OpenAI o3 — no extra setup needed. Suitable for personal computer use.
# "medgemma" requires a local MedGemma + LoRA checkpoint (HPC/research use).
REPORT_SCORER=gpt
